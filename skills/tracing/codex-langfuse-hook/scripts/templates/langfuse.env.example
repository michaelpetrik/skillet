CODEX_LANGFUSE_ENABLED=true

# Actual Langfuse project routing is determined by these credentials.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://langfuse.example.com

# Optional logical label stored in Langfuse metadata/tags.
CODEX_LANGFUSE_PROJECT=default
CODEX_LANGFUSE_TAGS=personal,codex
CODEX_LANGFUSE_USER_ID=michal

# Export behavior.
CODEX_LANGFUSE_REDACTION_MODE=basic
CODEX_LANGFUSE_RAW_CHUNK_BYTES=180000
CODEX_LANGFUSE_TIMEOUT_SECONDS=4
